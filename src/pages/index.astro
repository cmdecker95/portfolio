---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Portfolio - Christian Decker">
  <main>
    <div class="scrolling-text">
      <h1><span>CHRISTIAN</span>CHRISTIAN</h1>
      <h1><span>DECKER</span>DECKER</h1>
    </div>
  </main>
</Layout>

<style>
  .scrolling-text {
    display: flex;
    overflow: hidden;
    width: 100%;
  }

  h1 {
    background: url("Space Background.png");
    background-clip: text;
    -webkit-background-clip: text;
    color: transparent;
    font-family: Roboto Mono, system-ui, sans-serif;
    font-size: 10rem;
    font-weight: 700;
    line-height: 0.9;
    margin: 0;
    padding: 0;
    white-space: nowrap;
    animation: scrollLeft 20s linear infinite;
  }

  h1 span {
    color: var(--color-text);
    opacity: 0.9;
  }

  @keyframes scrollLeft {
    0% {
      transform: translateX(100%);
    }
    100% {
      transform: translateX(-100%);
    }
  }
	</style>