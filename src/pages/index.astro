</Layout>

<style>
  main {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    margin: 2rem 0;
  }

  section {
    padding: 0 2rem;
  }

  #top {
    border-bottom: 1px solid var(--color-border);
    display: grid;
    height: 300px;
    overflow: hidden;
    padding: 0;
    place-items: center;
    position: relative;
  }

  #top img {
    min-height: 100%;
    position: absolute;
    width: 100%;
    z-index: -1;
  }

  h1 {
    animation: blink 250ms linear;
    font-size: 7rem;
    font-weight: 900;
    letter-spacing: 0.9;
    line-height: 0.9;
    text-align: center;
  }

  @media (max-width: 768px) {
    #top {
      height: 200px;
    }
    h1 {
      font-size: 4rem;
    }
    h2 {
      font-size: 2rem;
    }
  }

  @media (max-width: 425px) {
    h1 {
      font-size: 3rem;
    }
    h2 {
      font-size: 1.5rem;
    }
  }

  #contact form {
    display: grid;
    grid-template-columns: 1fr 1fr;
  }

  @keyframes blink {
    0% {
      opacity: 0;
    }
    24% {
      opacity: 0;
    }
    25% {
      opacity: 0.5;
    }
    49% {
      opacity: 0.5;
      color: var(--color-accent);
    }
    50% {
      opacity: 0;
    }
    74% {
      opacity: 0;
    }
    75% {
      opacity: 0.5;
    }
    99% {
      opacity: 0.5;
      color: var(--color-accent);
    }
    100% {
      opacity: 1;
    }
  }
</style>
