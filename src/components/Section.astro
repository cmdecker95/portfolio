---
const { id, title } = Astro.props;
---

<section id={id}>
  <h2>{title}</h2>
  <ul class="card grid">
    <slot name="card" />
  </ul>
  <slot />
</section>

<style>
  section {
    padding: 0 2rem;
  }

  .card.grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    height: fit-content;
  }

  h2 {
    background: var(--color-bg-light);
    border-radius: 8px;
    color: var(--color-text-dark);
    padding: 1rem 2rem;
    width: fit-content;
  }
</style>
