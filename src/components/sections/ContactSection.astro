---
import Section from "../Section.astro";
---

<Section id="contact" title="Contact">
  <form name="contact" method="post" data-netlify="true" action="/thanks">
    <div class="row">
      <!-- Name -->
      <div class="group">
        <label for="name">Name</label>
        <input id="name" name="name" required />
      </div>

      <!-- Email -->
      <div class="group">
        <label for="email">Email</label>
        <input type="email" id="email" name="email" required />
      </div>
    </div>

    <!-- Message -->
    <div class="group.textarea">
      <label for="message"> Message</label>
      <textarea id="message" name="message" required></textarea>
    </div>
    <button>Send</button>
  </form>
</Section>

<style>
  form {
    background: var(--color-bg-light);
    border-radius: 8px;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 2rem;
  }

  .row {
    display: flex;
    gap: 1rem;
    width: 100%;
  }

  .group {
    display: flex;
    flex: 1;
    flex-direction: column;
    gap: 0.25rem;
  }

  .textarea {
    flex: 2;
  }

  .group:hover :is(input, textarea),
  :is(input, textarea):focus {
    outline: 1px solid var(--color-text-dark);
    outline-offset: 0px;
  }

  :is(label, input, textarea, button) {
    appearance: none;
    background: inherit;
    border: none;
    color: var(--color-text-dark);
    flex: 1;
    font-family: var(--font-family);
    outline: none;
  }

  :is(input, textarea) {
    background-color: var(--color-text);
    border: 1px solid var(--color-text-dark);
    border-radius: 4px;
    padding: 0.5rem;
    width: calc(100% - 1rem);
  }

  textarea {
    height: 100px;
  }

  button {
    background: var(--color-bg);
    border-radius: 4px;
    color: var(--color-text-light);
    height: fit-content;
    margin-inline: auto;
    padding: 1rem 2rem;
    width: fit-content;
  }

  button:hover,
  button:focus {
    cursor: pointer;
    outline: 2px solid green;
  }
</style>
