<style>
	main {
		display: flex;
		gap: 3rem;
		overflow-x: hidden;
		padding: 0 2rem;
	}

	#top {
		background: url("Space Background.png");
	}
	
  h1 {
    font-size: 8rem;
    font-weight: 700;
    white-space: nowrap;
    animation: scrollLeft 7s linear infinite;
  }
  
  @keyframes scrollLeft {
    0% {
      transform: translateX(-25%);
    }
    100% {
      transform: translateX(-50%);
    }
  }
	</style>